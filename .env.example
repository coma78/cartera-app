# ---- Base de datos (Railway la inyecta automaticamente como DATABASE_URL) ----
DATABASE_URL=postgres://user:pass@host:5432/dbname

# ---- Datos de mercado ----
# Proveedor: "finnhub" (recomendado, gratis) o "fmp"
MARKET_PROVIDER=finnhub
# API key del proveedor elegido (finnhub.io o financialmodelingprep.com)
MARKET_API_KEY=tu_api_key_aca

# ---- Envio de mail (Brevo) ----
BREVO_API_KEY=tu_brevo_api_key
# Remitente verificado en Brevo
MAIL_FROM_EMAIL=alertas@tudominio.com
MAIL_FROM_NAME=Cartera Bot
# A quien se le manda el reporte diario
MAIL_TO_EMAIL=gascazur@gmail.com

# ---- Reporte diario ----
# Hora local (0-23) a la que corre el reporte
REPORT_HOUR=8
REPORT_MINUTE=0
# Zona horaria IANA (ej. America/Argentina/Buenos_Aires)
TZ=America/Argentina/Buenos_Aires
# Moneda para mostrar (solo etiqueta)
CURRENCY=USD

# ---- Seguridad opcional de la UI ----
# Si lo seteas, la UI y la API piden este token (header x-app-token o ?token=)
APP_TOKEN=

# ---- Puerto (Railway lo inyecta) ----
PORT=3000
