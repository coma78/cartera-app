# ---- Base de datos (Railway la inyecta automaticamente como DATABASE_URL) ----
DATABASE_URL=postgres://user:pass@host:5432/dbname

# ---- Datos de mercado ----
# Proveedor: "finnhub" (recomendado, gratis) o "fmp"
MARKET_PROVIDER=finnhub
MARKET_API_KEY=tu_api_key_aca

# ---- Envio de mail ----
# Proveedor: "resend" (NO pide telefono) o "brevo"
MAIL_PROVIDER=resend
RESEND_API_KEY=tu_resend_api_key
BREVO_API_KEY=
MAIL_FROM_EMAIL=onboarding@resend.dev
MAIL_FROM_NAME=Cartera Bot
MAIL_TO_EMAIL=gascazur@gmail.com

# ---- Reporte diario ----
REPORT_HOUR=8
REPORT_MINUTE=0
TZ=America/Argentina/Buenos_Aires
CURRENCY=USD

# ---- Login con Google (SSO) ----
# Si dejas GOOGLE_CLIENT_ID vacio, el SSO queda DESACTIVADO (util en local).
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# Secreto para firmar la cookie de sesion (poné algo largo y aleatorio)
SESSION_SECRET=cambia-esto-por-algo-largo-y-aleatorio
# URL publica de la app (para el redirect de Google). Ej: https://cartera-app.up.railway.app
BASE_URL=
# Mails permitidos (separados por coma)
ALLOWED_EMAILS=gascazur@gmail.com

# ---- Seguridad alternativa (solo si NO usas SSO) ----
APP_TOKEN=

# ---- Puerto (Railway lo inyecta) ----
PORT=3000
